local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/BigRigV3/PD-internal/refs/heads/main/uilib"))()
-- esp is whats in  d
local ESP = loadstring(game:HttpGet("https://raw.githubusercontent.com/BigRigV3/PD-internal/refs/heads/main/esplib"))()

local Window = Library:Window({
    Name = 'Onix<font color="rgb(126, 192, 255)">.lol</font> | developer | lifetime',
    Rank = "developer"
})

do
    local Watermark = Window:Watermark({
        Name = "Onix.lol Private",
        SubName = "Project Delta"
    })

    local KeybindList = Window:KeybindList({
        Name = 'hot<font color="rgb(126, 192, 255)">keys</font>'
    })

    local StaffList = Window:StaffList({
        Name = 'staff<font color="rgb(0, 80, 255)"> list</font>'
    })

    StaffList:Add("Bigrig", "owner/dev")

    local TargetIndicator = Window:TargetIndicator({
        Name = "target<font color='rgb(0, 80, 255)'> info</font>"
    })

    TargetIndicator:SetTarget(game:GetService("Players").LocalPlayer)
end

local VisualsPage = Window:Page({Name = "visuals"})

do
